{
  "index_patterns": ["logs-recipegen.*"],
  "data_stream": {},
  "priority": 200,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "index.lifecycle.name": "recipegen-logs-lifecycle"
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "service": { "type": "keyword" },
        "component": { "type": "keyword" },
        "environment": { "type": "keyword" },
        "file": { "type": "keyword" },
        "level": { "type": "keyword" },
        "msg": { "type": "text" }
      }
    }
  }
}
